{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus / Mimir",
      "description": "Grafana Cloud Prometheus (metrics) datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "Grafana Cloud Loki (logs) datasource",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["xstockstrat", "phase7", "service-health"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "label": "Prometheus / Mimir"
      },
      {
        "name": "DS_LOKI",
        "type": "datasource",
        "query": "loki",
        "current": {},
        "hide": 0,
        "label": "Loki"
      },
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(rpc_server_duration_milliseconds_count, service_name)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "",
  "title": "xstockstrat — Service Health",
  "uid": "xstk-service-health",
  "panels": [
    {
      "title": "Request rate (gRPC req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service_name) (rate(rpc_server_duration_milliseconds_count{service_name=~\"$service\"}[5m]))",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "title": "Error rate (% of gRPC calls, non-OK status)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum by (service_name) (rate(rpc_server_duration_milliseconds_count{service_name=~\"$service\", rpc_grpc_status_code!=\"0\"}[5m])) / clamp_min(sum by (service_name) (rate(rpc_server_duration_milliseconds_count{service_name=~\"$service\"}[5m])), 0.001)",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "title": "P99 gRPC latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 2000 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le, service_name) (rate(rpc_server_duration_milliseconds_bucket{service_name=~\"$service\"}[5m])))",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "title": "Log error volume by service (errors/s)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service_name) (rate({platform=\"xstockstrat\", service_name=~\"$service\"} | json | level=~\"error|ERROR\" [5m]))",
          "legendFormat": "{{service_name}}"
        }
      ]
    }
  ]
}
