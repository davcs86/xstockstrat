{
  "$schema": "https://tr.designtokens.org/format/",
  "$metadata": {
    "description": "xstockstrat design tokens — extracted from all three Next.js UI services (trader, insights, config-ui). All services share an identical globals.css and tailwind.config.js.",
    "services": ["xstockstrat-trader", "xstockstrat-insights", "xstockstrat-config-ui"],
    "source": "services/*/src/app/globals.css + services/*/tailwind.config.js"
  },
  "color": {
    "$type": "color",
    "background": {
      "$value": "hsl(222, 47%, 4%)",
      "$description": "Page / app shell background — deep navy",
      "figma": { "cssVar": "--background" }
    },
    "foreground": {
      "$value": "hsl(213, 31%, 91%)",
      "$description": "Default text colour on background",
      "figma": { "cssVar": "--foreground" }
    },
    "card": {
      "$value": "hsl(222, 47%, 7%)",
      "$description": "Card / panel surface",
      "figma": { "cssVar": "--card" }
    },
    "card-foreground": {
      "$value": "hsl(213, 31%, 91%)",
      "$description": "Text on cards",
      "figma": { "cssVar": "--card-foreground" }
    },
    "popover": {
      "$value": "hsl(222, 47%, 7%)",
      "$description": "Popover / dropdown surface",
      "figma": { "cssVar": "--popover" }
    },
    "popover-foreground": {
      "$value": "hsl(213, 31%, 91%)",
      "$description": "Text in popovers",
      "figma": { "cssVar": "--popover-foreground" }
    },
    "primary": {
      "$value": "hsl(163, 100%, 44%)",
      "$description": "Brand primary — bright green/teal (buy, active states, logo)",
      "figma": { "cssVar": "--primary" }
    },
    "primary-foreground": {
      "$value": "hsl(222, 47%, 4%)",
      "$description": "Text on primary backgrounds",
      "figma": { "cssVar": "--primary-foreground" }
    },
    "secondary": {
      "$value": "hsl(222, 20%, 14%)",
      "$description": "Secondary surface (muted panels, secondary buttons)",
      "figma": { "cssVar": "--secondary" }
    },
    "secondary-foreground": {
      "$value": "hsl(213, 31%, 91%)",
      "$description": "Text on secondary surfaces",
      "figma": { "cssVar": "--secondary-foreground" }
    },
    "muted": {
      "$value": "hsl(222, 20%, 14%)",
      "$description": "Muted surface (same as secondary)",
      "figma": { "cssVar": "--muted" }
    },
    "muted-foreground": {
      "$value": "hsl(215, 16%, 47%)",
      "$description": "De-emphasised text — labels, placeholders, helper text",
      "figma": { "cssVar": "--muted-foreground" }
    },
    "accent": {
      "$value": "hsl(222, 20%, 18%)",
      "$description": "Hover / focus surface (slightly lighter than secondary)",
      "figma": { "cssVar": "--accent" }
    },
    "accent-foreground": {
      "$value": "hsl(213, 31%, 91%)",
      "$description": "Text on accent surfaces",
      "figma": { "cssVar": "--accent-foreground" }
    },
    "destructive": {
      "$value": "hsl(0, 84%, 60%)",
      "$description": "Error / destructive actions",
      "figma": { "cssVar": "--destructive" }
    },
    "destructive-foreground": {
      "$value": "hsl(210, 40%, 98%)",
      "$description": "Text on destructive surfaces",
      "figma": { "cssVar": "--destructive-foreground" }
    },
    "border": {
      "$value": "hsl(222, 20%, 14%)",
      "$description": "Default border colour",
      "figma": { "cssVar": "--border" }
    },
    "input": {
      "$value": "hsl(222, 20%, 14%)",
      "$description": "Input field border / background",
      "figma": { "cssVar": "--input" }
    },
    "ring": {
      "$value": "hsl(163, 100%, 44%)",
      "$description": "Focus ring — matches primary",
      "figma": { "cssVar": "--ring" }
    },
    "buy": {
      "$value": "hsl(163, 100%, 40%)",
      "$description": "Domain colour — BUY side (slightly darker than primary)",
      "figma": { "cssVar": "buy" }
    },
    "sell": {
      "$value": "hsl(0, 84%, 55%)",
      "$description": "Domain colour — SELL side (red)",
      "figma": { "cssVar": "sell" }
    },
    "paper": {
      "$value": "hsl(48, 96%, 53%)",
      "$description": "Domain colour — PAPER trading mode (yellow/amber)",
      "figma": { "cssVar": "paper" }
    }
  },
  "radius": {
    "$type": "dimension",
    "base": {
      "$value": "0.5rem",
      "$description": "Base border radius (--radius). lg variant. Used as var(--radius) in Tailwind config.",
      "figma": { "cssVar": "--radius" }
    },
    "md": {
      "$value": "calc(0.5rem - 2px)",
      "$description": "Medium border radius — calc(var(--radius) - 2px)"
    },
    "sm": {
      "$value": "calc(0.5rem - 4px)",
      "$description": "Small border radius — calc(var(--radius) - 4px)"
    }
  },
  "typography": {
    "$type": "fontFamily",
    "sans": {
      "$value": "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
      "$description": "Base sans-serif stack (Next.js default, no custom font loaded)",
      "figma": { "feature-settings": "\"rlig\" 1, \"calt\" 1" }
    }
  }
}
