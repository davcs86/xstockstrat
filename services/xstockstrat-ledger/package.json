{
  "name": "xstockstrat-ledger",
  "version": "0.1.0",
  "description": "Append-only event store — all services write events here",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "migrate": "node-pg-migrate up",
    "proto:gen": "cd ../../packages/proto && buf generate"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^1.10.0",
    "@connectrpc/connect": "^1.4.0",
    "@connectrpc/connect-node": "^1.4.0",
    "@grpc/grpc-js": "^1.10.9",
    "@grpc/proto-loader": "^0.7.13",
    "google-protobuf": "^3.21.4",
    "pg": "^8.11.5",
    "uuid": "^9.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^9.0.8",
    "node-pg-migrate": "^7.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
