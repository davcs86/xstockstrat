# .env.local — committed local dev structural overrides. No secrets here.
# Loaded by Next.js (all modes) and docker-compose (via env_file: [".env.local"]).
# DO deployments use app.dev.yaml / app.yaml — this file is NOT loaded there.
APPLICATION_ENV=development
NODE_ENV=development
# otel-collector upstream — override in .env with the real Grafana Cloud URL when enabling OTel
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
