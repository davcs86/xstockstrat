!packages/proto/gen/ts/dist/
**/node-compile-cache/
**/.turbo/
**/*.tsbuildinfo
**/.env.local
**/.env.development.local
**/.env.production.local

# Environment secrets — NEVER commit these
.env
.env.*
!.env.example
!.env.development
!.env.production
!.env.local
**/.env
**/.env.*
!**/.env.example
!**/.env.development
!**/.env.production
!**/.env.local

# Docker
**/docker-compose.override.yml

# Secret file types — NEVER commit private keys or credential files
*.pem
*.key
*.p12
*.pfx
secrets.*
credentials.*
service-account*.json
*-service-account.json

# OS
.DS_Store
Thumbs.db

