# xstockstrat-orchestration — Environment Variables Example
# Copy to .env and fill in real values. NEVER commit .env to git.
#
# Two-file convention:
#   .env.local  — committed; structural local-dev overrides (APPLICATION_ENV, APP_URL,
#                 NODE_ENV). No secrets. Loaded by docker-compose (env_file) and Next.js.
#   .env        — not committed; secrets only (POSTGRES_PASSWORD, DATABASE_URL,
#                 ALPACA_*, JWT_SECRET, etc.). Copy .env.example → .env to get started.
#
# DigitalOcean App Platform: secrets are set once via `doctl apps update --set-env`
# or the DO dashboard (App → Settings → Environment Variables → Encrypt). They are
# NEVER stored in committed files. See docs/setup/digitalocean.md Step 7.

# ── Database ───────────────────────────────────────────────────────────────
# Local dev only. In production, both vars are injected by DigitalOcean App Platform
# from the managed database component — never stored here or in git.
#
# POSTGRES_PASSWORD is used by the Docker Compose TimescaleDB container.
# DATABASE_URL must use the same password as POSTGRES_PASSWORD.
# Change both together if you pick a custom password.
POSTGRES_PASSWORD=devpassword
DATABASE_URL=postgres://xstockstrat:devpassword@localhost:5432/xstockstrat?sslmode=disable

# ── Alpaca Credentials (shared by xstockstrat-marketdata + xstockstrat-trading) ─
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_API_SECRET=your-alpaca-api-secret

# ── Alpaca Market Data API (xstockstrat-marketdata only) ──────────────────
# ALPACA_BASE_URL selects the REST endpoint for broker/asset queries (paper vs live).
# xstockstrat-trading URLs are hardcoded constants — not configurable via env.
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# ── JWT (xstockstrat-identity only) ───────────────────────────────────────
JWT_SECRET=change-me-in-production-use-32-char-minimum

# ── Service Endpoints (used by frontends and inter-service clients) ────────
CONFIG_ENDPOINT=xstockstrat-config:50060
LEDGER_ENDPOINT=xstockstrat-ledger:50057
IDENTITY_ENDPOINT=xstockstrat-identity:50058
NOTIFY_ENDPOINT=xstockstrat-notify:50059
MARKETDATA_ENDPOINT=xstockstrat-marketdata:50053
TRADING_ENDPOINT=xstockstrat-trading:50051
PORTFOLIO_ENDPOINT=xstockstrat-portfolio:50052
INDICATORS_ENDPOINT=xstockstrat-indicators:50054
INGEST_ENDPOINT=xstockstrat-ingest:50055
ANALYSIS_ENDPOINT=xstockstrat-analysis:50056

# ── n8n Cloud ──────────────────────────────────────────────────────────────
N8N_WEBHOOK_SECRET=change-me-n8n-webhook-secret

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── OpenTelemetry (Observability) ──────────────────────────────────────────
# Set OTEL_ENABLED=true to activate OTLP export from all services.
# See docs/setup/grafana-cloud.md for full setup instructions.
#
# Local dev: services push to the otel-collector Docker Compose container,
#            which forwards to Grafana Cloud. Requires a Grafana Cloud account.
# Production: services push OTLP directly to Grafana Cloud (no collector needed).
OTEL_ENABLED=false

# Grafana Cloud OTLP gateway — generated at:
#   Grafana Cloud → Connections → Add new connection → OpenTelemetry
# Example: https://otlp-gateway-prod-us-central-0.grafana.net/otlp
GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-<region>.grafana.net/otlp

# Grafana Cloud OTLP token — pre-encoded base64 <instanceId>:<apiKey>
# Grafana provides this value ready-to-use on the same connection page.
# Used by the otel-collector in docker-compose (local dev only).
# In production, set OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <token> per service.
GRAFANA_OTLP_TOKEN=<base64-encoded-instance-id-and-api-key>

# ═══════════════════════════════════════════════════════════════════════════
# GitHub Repository Secrets (NOT local .env — set in GitHub only)
# ═══════════════════════════════════════════════════════════════════════════
# The variables below are NOT used locally. They must be added as repository
# secrets in GitHub → Settings → Secrets and variables → Actions.
# See docs/setup/digitalocean.md Step 9 for setup instructions.
#
# Secret Name               Used by workflow            How to obtain
# ─────────────────────────────────────────────────────────────────────────
# DIGITALOCEAN_ACCESS_TOKEN deploy-dev / deploy-prod    DigitalOcean API PAT
# DO_DEV_APP_ID             deploy-dev                  doctl apps list (dev app)
# DO_PROD_APP_ID            deploy-prod                 doctl apps list (prod app)
# BUF_TOKEN                 deploy-dev / deploy-prod    buf.build → Settings → Tokens
# GH_PAT_SCAN               ci (secret-scan job)        GitHub PAT with repo read scope
#
# GITHUB_TOKEN is automatically provided by GitHub Actions — no setup needed.
