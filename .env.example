# xstockstrat-orchestration — Environment Variables Example
# Copy to .env and fill in real values. NEVER commit .env to git.

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgres://xstockstrat:devpassword@localhost:5432/xstockstrat?sslmode=disable

# ── Alpaca Credentials (shared by xstockstrat-marketdata + xstockstrat-trading) ─
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_API_SECRET=your-alpaca-api-secret
# true = paper trading (default); false = live real-money trading
ALPACA_PAPER=true

# ── Alpaca Market Data API (xstockstrat-marketdata only) ──────────────────
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# ── Alpaca Broker / Order API (xstockstrat-trading only) ──────────────────
ALPACA_PAPER_URL=https://paper-api.alpaca.markets
ALPACA_LIVE_URL=https://api.alpaca.markets

# ── JWT (xstockstrat-identity only) ───────────────────────────────────────
JWT_SECRET=change-me-in-production-use-32-char-minimum

# ── Service Endpoints (used by frontends and inter-service clients) ────────
CONFIG_ENDPOINT=xstockstrat-config:50060
LEDGER_ENDPOINT=xstockstrat-ledger:50057
IDENTITY_ENDPOINT=xstockstrat-identity:50058
NOTIFY_ENDPOINT=xstockstrat-notify:50059
MARKETDATA_ENDPOINT=xstockstrat-marketdata:50053
TRADING_ENDPOINT=xstockstrat-trading:50051
PORTFOLIO_ENDPOINT=xstockstrat-portfolio:50052
INDICATORS_ENDPOINT=xstockstrat-indicators:50054
INGEST_ENDPOINT=xstockstrat-ingest:50055
ANALYSIS_ENDPOINT=xstockstrat-analysis:50056

# ── n8n Cloud ──────────────────────────────────────────────────────────────
N8N_WEBHOOK_SECRET=change-me-n8n-webhook-secret

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
