{
  "$schema": "https://raw.githubusercontent.com/kucherenko/jscpd/master/packages/jscpd/schema.json",
  "//minTokens": "Clone size floor. 100 catches real logic duplication (helpers, types, components) while ignoring low-density structural noise such as identical multi-line import blocks across sibling files, which are not refactorable DRY violations.",
  "minTokens": 100,
  "reporters": ["console"],
  "gitignore": true,
  "absolute": false,
  "ignore": [
    "**/node_modules/**",
    "**/.next/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/test-results/**",
    "**/playwright-report/**",
    "packages/proto/gen/**",
    "**/*_pb.ts",
    "**/*_pb.py",
    "**/*.pb.go",
    "**/*_grpc.py",
    "**/migrations/**",
    "**/*_test.go",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/e2e/**",
    "**/tests/**",
    "**/testdata/**",
    "**/__tests__/**",
    "**/test_*.py",
    "**/*.lock",
    "**/pnpm-lock.yaml",
    "**/uv.lock",
    "**/go.sum"
  ]
}
